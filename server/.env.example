# Copy to .env and edit. NEVER commit .env (it is in .gitignore).

# Port the API listens on
PORT=4000

# Comma-separated origins allowed by CORS (the frontend dev server)
CORS_ORIGIN=http://localhost:5173

# OPTIONAL persistence. Leave blank to use the in-memory store (zero setup).
# When set, cache entries + action queue persist across restarts (idempotency survives).
# NOTE: this is a TEMPLATE — never put a real username/password here. Put the real
# value only in server/.env (which is gitignored and never committed).
MONGO_URI=mongodb+srv://<user>:<password>@<cluster>.mongodb.net/?appName=Cluster0
MONGO_DB=ops_dashboard

# Global default cache TTL in seconds (each source can override)
DEFAULT_TTL_SECONDS=300

# A contact User-Agent sent to public APIs that ask for one (good citizenship)
USER_AGENT=OperationsDashboard/1.0 (contact: airepublic7@gmail.com)
