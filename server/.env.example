# ──────────────────────────────────────────────────────────────────────────
# The Operations Dashboard — environment configuration
# Copy this file to `.env` and fill in any keys you have. The app runs with
# ZERO keys: every keyed adapter falls back to deterministic demo() data.
# NEVER commit .env (it is gitignored). Put real values only in .env.
# ──────────────────────────────────────────────────────────────────────────

# ---- Core server config ----
PORT=4000                         # HTTP port the API listens on
NODE_ENV=development              # development | production
SESSION_SECRET=                   # random string (e.g. `openssl rand -hex 32`) — Level 3 auth
DEMO_PASSWORD=demo1234            # password for seeded demo users (founder/analyst) — Level 3
REFRESH_CRON=*/10 * * * *         # node-cron schedule for the background refresh job — Level 4
CORS_ORIGIN=http://localhost:5173 # comma-separated allowed CORS origins

# ---- Persistence (optional). Blank = zero-setup in-memory store. ----
MONGO_URI=                        # mongodb+srv://<user>:<pass>@<cluster>.mongodb.net/?appName=Cluster0
MONGO_DB=ops_dashboard

# ---- Cache + citizenship ----
DEFAULT_TTL_SECONDS=300
USER_AGENT=OperationsDashboard/1.0 (contact: you@example.com)

# ---- PUBLIC sources (A1..A8): no key required ----

# ---- KEYED sources (B1..B10): blank = demo() fallback ----
ALPHAVANTAGE_KEY=                 # B1 Alpha Vantage (25 requests/DAY limit!)
OPENWEATHER_KEY=                  # B2 OpenWeatherMap
NEWSAPI_KEY=                      # B3 NewsAPI (sent as X-Api-Key header)
FRED_KEY=                         # B4 FRED (St. Louis Fed)
USAJOBS_KEY=                      # B5 USAJOBS Authorization-Key header
USAJOBS_EMAIL=                    # B5 USAJOBS User-Agent (your contact email)
CLOCKIFY_KEY=                     # B6 Clockify X-Api-Key header
CLOCKIFY_WORKSPACE=               # B6 Clockify workspace id
NOTION_TOKEN=                     # B7 Notion integration token (Bearer)
NOTION_DB_ID=                     # B7 Notion database id to query
AIRTABLE_PAT=                     # B8 Airtable personal access token (Bearer)
AIRTABLE_BASE=                    # B8 Airtable base id
AIRTABLE_TABLE=Clients            # B8 Airtable table name
TRELLO_KEY=                       # B9 Trello API key
TRELLO_TOKEN=                     # B9 Trello API token
TRELLO_BOARD=                     # B9 Trello board id
AQICN_TOKEN=                      # B10 AQICN / WAQI feed token

# ---- SCRAPERS (C1..C7): identify yourself per each site's policy ----
SEC_EDGAR_UA=                     # C1 SEC EDGAR User-Agent ("Name email@example.com")
